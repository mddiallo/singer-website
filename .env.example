# Azure Table Storage — set these as Application Settings in Azure Portal
# NEVER commit a .env file with real values to git
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_TABLE_NAME=FanSubscribers

# Set to your Azure SWA production URL to restrict CORS in production
ALLOWED_ORIGIN=https://your-site.azurestaticapps.net
